#include <stdio.h>
int main() {
    int n;
    printf("Введіть довжину послідовності n: ");
    scanf("%d", &n);
    long a[10001];
    long mod = 12345;
    a[0] = 1;
    a[1] = 2;
    a[2] = 4;
    for (int i = 3; i <= n; i++) {
        a[i] = (a[i - 1] + a[i - 2] + a[i - 3]) % mod;
    }
    printf("Кількість шуканих послідовностей: %ld\n", a[n]);
    return 0;
}
